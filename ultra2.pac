        for(var i=0;i<m.length;i++)for(var j=0;j<m[i][1].length;j++)if(c.indexOf(m[i][1][j])!==-1){
            if(m[i][0]!==this.ph){this.ph=m[i][0];if(m[i][0]==="G"||m[i][0]==="MM")AN.lock(this.ch||safeChain(MY_CHAIN));}
            return m[i][0];
        }
        return this.ph;
    }
};

// ═══ TIME ═══
var TM={
    h:function(){return(new Date().getUTCHours()+3)%24;},
    d:function(){return new Date().getUTCDay();},
    peak:function(){var h=this.h();return h>=19&&h<=23;},
    quality:function(){
        if(this.d()===5&&this.peak())return 100;
        if(this.peak())return 90;
        if(this.d()===5)return 80;
        var h=this.h();
        if(h>=16&&h<19)return 70;
        if(h>=0&&h<=3)return 50;
        return 55;
    },
    best:function(){if(this.quality()>=80)return["ORANGE_A","ZAIN_A"];return MY_CHAIN.slice(0,2);}
};

// ═══ DNS + STICKY + HELPERS ═══
var DC={},DK=[];
function dR(h){var e=DC[h];if(e&&now()-e.t<=8000)return e;var t0=now();var ip=dnsResolve(h);var dt=now()-t0;var r={ip:ip,dt:dt,t:now()};if(DK.length>=100){var o=DK.shift();delete DC[o];}DC[h]=r;DK.push(h);PE.sample(dt);return r;}
var SC={};
function sG(k){var e=SC[k];if(!e)return null;if(now()-e.t>300000){delete SC[k];return null;}return e.v;}
function sS(k,v){SC[k]={v:v,t:now()};}
function now(){return(new Date()).getTime();}
function isV4(ip){if(!ip||ip.indexOf(":")!==-1)return false;var p=ip.split(".");if(p.length!==4)return false;for(var i=0;i<4;i++){var n=parseInt(p[i],10);if(isNaN(n)||n<0||n>255)return false;}return true;}
function safeChain(names){var out="",c=0;for(var i=0;i<names.length;i++){var p=POOL[names[i]];if(!p)continue;if(out!=="")out+="; ";out+="PROXY "+p.ip+":"+p.port;c++;if(c>=CFG.MAX_FB)break;}if(out!=="")return out+"; "+B.X;return B.X;}

var BC={},BM=0;


// ═══════════════════════════════════════════════════════════════
//  FindProxyForURL
// ═══════════════════════════════════════════════════════════════

function FindProxyForURL(url,host){
    if(!host)return B.D;
    var h=host.toLowerCase();

    // Local
    if(isPlainHostName(host))return B.D;
    if(isV4(host)){if(isInNet(host,"10.0.0.0","255.0.0.0")||isInNet(host,"172.16.0.0","255.240.0.0")||isInNet(host,"192.168.0.0","255.255.0.0")||isInNet(host,"127.0.0.0","255.0.0.0"))return B.D;}

    // PUBG?
    if(!BF.host(h))return B.D;

    // Cache
    var cc=BC[host];
    if(cc&&now()-cc.t<CFG.DEC_TTL)return cc.p;
    BM++;

    // Anchor
    var lk=AN.get();
    if(lk){BC[host]={p:lk,t:now()};return lk;}

    // Phase
    var ph=SS.phase(host,url);

    // Region Pin
    if(h.indexOf("region")!==-1||h.indexOf("geo")!==-1||h.indexOf("server_list")!==-1||h.indexOf("serverlist")!==-1||h.indexOf("location")!==-1||h.indexOf("locale")!==-1||h.indexOf("device.info")!==-1||h.indexOf("network.info")!==-1){
        var ch=safeChain(["ORANGE_A","ZAIN_A"]);
        AN.lock(ch);BC[host]={p:ch,t:now()};return ch;
    }

    // Telemetry
    if(h.indexOf("analytics")!==-1||h.indexOf("telemetry")!==-1||h.indexOf("tracking")!==-1||h.indexOf("monitor")!==-1||h.indexOf("report")!==-1){
        var ch=safeChain(["ORANGE_A","ZAIN_A"]);
        AN.lock(ch);BC[host]={p:ch,t:now()};return ch;
    }

    // Auth
    if(ph==="AU"){
        var ch=safeChain(["ORANGE_A","ZAIN_A","UMNIAH_A"]);
        AN.lock(ch);BC[host]={p:ch,t:now()};return ch;
    }

    // Lobby
    if(ph==="LB"){
        var sk=sG("LB");
        if(sk){BC[host]={p:sk,t:now()};return sk;}
        var ch=safeChain(MY_CHAIN.slice(0,3));
        sS("LB",ch);SS.ch=ch;BC[host]={p:ch,t:now()};return ch;
    }

    // Matchmaking
    if(ph==="MM"){
        var ch=safeChain(["ORANGE_A","ZAIN_A"]);
        AN.lock(ch);BC[host]={p:ch,t:now()};return ch;
    }

    // In-Game
    if(ph==="G"){
        if(SP.far(h)){var ch=safeChain(["ORANGE_A"]);AN.lock(ch);BC[host]={p:ch,t:now()};return ch;}
        var ch=safeChain(["ORANGE_A"]);
        AN.lock(ch);BC[host]={p:ch,t:now()};return ch;
    }

    // Post-Game
    if(ph==="PG"){
        if(AN.on){BC[host]={p:AN.ch,t:now()};return AN.ch;}
        var ch=safeChain(MY_CHAIN.slice(0,3));
        BC[host]={p:ch,t:now()};return ch;
    }

    // Update
    if(ph==="UP"){
        var ch=safeChain(["ZAIN_A","UMNIAH_A","ORANGE_B","ST_A"]);
        BC[host]={p:ch,t:now()};return ch;
    }

    // DNS
    var dn=dR(host);
    var ip=dn.ip;

    // IP Analysis
    var isJo=false,isCl=false,car="U";
    if(ip&&isV4(ip)){isJo=IP.isJo(ip);isCl=!isJo&&IP.isCl(ip);car=IP.car(ip);}

    // Score
    var sc=0;
    if(isJo)sc+=40;
    if(IP.my(ip))sc+=20;
    if(car==="ORANGE")sc+=15;else if(car==="ZAIN")sc+=13;else if(car==="UMNIAH")sc+=10;
    if(dn.dt<=6)sc+=28;else if(dn.dt<=12)sc+=24;else if(dn.dt<=25)sc+=18;else sc-=5;
    var gr=PE.grade();
    if(gr==="SS")sc+=35;else if(gr==="S+")sc+=30;else if(gr==="S")sc+=25;else if(gr==="A")sc+=18;else sc-=15;
    if(isCl)sc-=15;
    if(SP.near(h))sc+=15;
    if(SP.far(h))sc-=30;
    sc+=Math.round(TM.quality()/10);
    sc=Math.max(0,Math.min(100,sc));

    // Proxy Select
    var proxy;
    if(PE.crit()){proxy=safeChain(["ZAIN_A","ORANGE_A","UMNIAH_A","ST_A"]);}
    else if(sc>=85){var tb=TM.best();proxy=safeChain(tb.slice(0,2));}
    else if(sc>=55){proxy=safeChain(MY_CHAIN.slice(0,3));}
    else{proxy=safeChain(MY_CHAIN);}

    if(SP.far(h))proxy=safeChain(["ORANGE_A"]);
    if(SP.near(h))proxy=safeChain(["ORANGE_A","ZAIN_A"]);

    SS.ch=proxy;
    BC[host]={p:proxy,t:now()};
    if(BM%40===0){for(var k in BC)if(now()-BC[k].t>CFG.DEC_TTL*3)delete BC[k];}
    return proxy;
}
