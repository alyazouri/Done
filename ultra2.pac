var AN={
    on:false,ch:null,at:0,
    lock:function(c){if(this.on&&!this.exp())return;this.on=true;this.ch=c;this.at=now();},
    get:function(){if(!this.on)return null;if(this.exp()){this.on=false;return null;}return this.ch;},
    exp:function(){return this.on&&(now()-this.at>9000000);},
    renew:function(){if(this.on)this.at=now();}
};

