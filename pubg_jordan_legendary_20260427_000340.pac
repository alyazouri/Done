//  BLOOM FILTER — مطابقة O(1)
// ═══════════════════════════════════════════════════════════════

var BLOOM = {
    bits: new Array(1024),
    size: 1024,

    init: function() {
        for (var i = 0; i < this.size; i++) this.bits[i] = 0;
    },

    h1: function(s) {
        var h = 0;
        for (var i = 0; i < s.length; i++)
            h = ((h << 5) - h + s.charCodeAt(i)) | 0;
        return Math.abs(h) % this.size;
    },
    h2: function(s) {
        var h = 5381;
        for (var i = 0; i < s.length; i++)
            h = ((h << 5) + h + s.charCodeAt(i)) | 0;
        return Math.abs(h) % this.size;
    },
    h3: function(s) {
        var h = 0;
        for (var i = 0; i < s.length; i++)
            h = (h * 31 + s.charCodeAt(i)) | 0;
        return Math.abs(h) % this.size;
    },
    h4: function(s) {
        var h = 17;
        for (var i = 0; i < s.length; i++)
            h = (h * 13 + s.charCodeAt(i) * 7) | 0;
        return Math.abs(h) % this.size;
    },

    add: function(w) {
        var l = w.toLowerCase();
        this.bits[this.h1(l)] = 1;
        this.bits[this.h2(l)] = 1;
        this.bits[this.h3(l)] = 1;
        this.bits[this.h4(l)] = 1;
    },

    buildFrom: function(arr) {
        this.init();
        for (var i = 0; i < arr.length; i++) this.add(arr[i]);
    },

    test: function(w) {
        var l = w.toLowerCase();
        return this.bits[this.h1(l)] === 1 &&
               this.bits[this.h2(l)] === 1 &&
               this.bits[this.h3(l)] === 1 &&
               this.bits[this.h4(l)] === 1;
    },

    testHost: function(h) {
        var parts = h.split(/[.\-_\/]/);
        for (var i = 0; i < parts.length; i++) {
            if (parts[i].length >= 3 && this.test(parts[i])) return true;
        }
        for (var len = 4; len <= Math.min(12, h.length); len++) {
            for (var pos = 0; pos <= h.length - len; pos++) {
                if (this.test(h.substr(pos, len))) return true;
            }
        }
        return false;
    }
};

