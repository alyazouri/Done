            "212.0.0.0/8","213.0.0.0/8"
        ];
        for (var i = 0; i < menaData.length; i++) {
            var parts = menaData[i].split("/");
            var r = this.cidr(parts[0], parts[1]);
            this.menaRanges.push(r);
        }
    },

    isJordan: function(ip) {
        var ipInt = this.ipToInt(ip);
        if (!ipInt) return false;
        for (var i = 0; i < this.joRanges.length; i++) {
            var r = this.joRanges[i];
            if (ipInt >= r.n && ipInt <= r.b) return true;
        }
        return false;
    },

    isCloudForeign: function(ip) {
        var ipInt = this.ipToInt(ip);
        if (!ipInt) return false;
        for (var i = 0; i < this.cloudRanges.length; i++) {
            var r = this.cloudRanges[i];
            if (ipInt >= r.n && ipInt <= r.b) return true;
        }
        return false;
    },

    isMENA: function(ip) {
        var ipInt = this.ipToInt(ip);
        if (!ipInt) return false;
        for (var i = 0; i < this.menaRanges.length; i++) {
            var r = this.menaRanges[i];
            if (ipInt >= r.n && ipInt <= r.b) return true;
        }
        return false;
    },

    carrier: function(ip) {
        var ipInt = this.ipToInt(ip);
        if (!ipInt) return "UNKNOWN";
        for (var i = 0; i < this.joRanges.length; i++) {
            var r = this.joRanges[i];
            if (ipInt >= r.n && ipInt <= r.b) return r.c;
        }
        return "OTHER";
    }
};

