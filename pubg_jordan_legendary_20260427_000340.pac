var IP_MATCH = {
    joRanges: [],
    cloudRanges: [],
    menaRanges: [],

    ipToInt: function(ip) {
        if (!ip) return 0;
        var p = ip.split(".");
        if (p.length !== 4) return 0;
        return ((parseInt(p[0],10) << 24) | (parseInt(p[1],10) << 16) |
                (parseInt(p[2],10) << 8) | parseInt(p[3],10)) >>> 0;
    },

    cidr: function(ipStr, bits) {
        var ip = this.ipToInt(ipStr);
        var mask = ~(0xFFFFFFFF >>> parseInt(bits,10)) >>> 0;
        return { n: (ip & mask) >>> 0, b: (ip | ~mask) >>> 0 };
    },

    build: function() {
        var joData = [
            ["46.185.128.0","20","ORANGE"],["46.185.144.0","21","ORANGE"],
            ["79.173.192.0","18","ZAIN"],["79.173.240.0","21","ZAIN"],
