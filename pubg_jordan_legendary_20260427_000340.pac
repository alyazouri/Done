            "104.16.0.0/12","172.64.0.0/13","188.114.96.0/20",
            "162.158.0.0/15","198.41.128.0/17","141.101.64.0/18",
            "108.162.192.0/18","173.245.48.0/20",
            "13.224.0.0/14","99.84.0.0/16","3.0.0.0/8",
            "52.84.0.0/15","54.192.0.0/16",
            "151.101.0.0/16","199.232.0.0/16"
        ];
        for (var i = 0; i < cloudData.length; i++) {
            var parts = cloudData[i].split("/");
            var r = this.cidr(parts[0], parts[1]);
            this.cloudRanges.push(r);
